var unlockedRaceNames = [];
var savedUnlockedRaces = [];
var bestLevel = 0;
var lastRunLevel = 0;
var lastRunKills = 0;

var SelectScene = new Phaser.Class({
    Extends: Phaser.Scene,

    initialize: function SelectScene() {
        Phaser.Scene.call(this, { key: 'SelectScene' });
    },

    create: function() {
        this.cameras.main.setBackgroundColor('#0a0a1a');

        var commonRaces = [
            { name: 'Human', size: 'average', strMod: 0, agiMod: 0, endMod: 0, intMod: 0, passive: 'Adaptable: Broader skill development', color: '#cccccc', tier: 'common' },
            { name: 'High Elf', size: 'average', strMod: -1, agiMod: 1, endMod: -1, intMod: 4, passive: 'Arcane Blood: Higher magic affinity', color: '#aaddff', tier: 'common' },
            { name: 'Wood Elf', size: 'small', strMod: -2, agiMod: 3, endMod: -1, intMod: 2, passive: 'Forest Walk: Concealment in forests', color: '#88cc66', tier: 'common' },
            { name: 'Hill Dwarf', size: 'small', strMod: 2, agiMod: -2, endMod: 3, intMod: -1, passive: 'Stout: Cheaper stamina for crafting', color: '#cc8844', tier: 'common' },
            { name: 'Mountain Dwarf', size: 'small', strMod: 3, agiMod: -2, endMod: 2, intMod: -1, passive: 'Stone Blood: Cheaper mining stamina', color: '#aa7733', tier: 'common' },
            { name: 'Kobold', size: 'small', strMod: -2, agiMod: 3, endMod: -1, intMod: 0, passive: 'Dark Vision: See in darkness', color: '#ddaa44', tier: 'common' },
            { name: 'Gnome', size: 'small', strMod: -3, agiMod: 2, endMod: -1, intMod: 4, passive: 'Tinker: Bonus to crafting', color: '#ee8866', tier: 'common' }
        ];

        var uncommonRaces = [
            { name: 'Wood Sprite', size: 'tiny', strMod: -4, agiMod: 5, endMod: -3, intMod: 3, passive: 'Fey Cloak: Forest concealment', color: '#44ff88', tier: 'uncommon' },
            { name: 'Troll', size: 'large', strMod: 5, agiMod: -3, endMod: 4, intMod: -4, passive: 'Regeneration: Slowly recover HP', color: '#55aa55', tier: 'uncommon' },
            { name: 'Bugbear', size: 'large', strMod: 4, agiMod: -2, endMod: 3, intMod: -3, passive: 'Brute Force: Bonus melee damage', color: '#886644', tier: 'uncommon' },
            { name: 'Celestial Pixie', size: 'tiny', strMod: -5, agiMod: 6, endMod: -4, intMod: 5, passive: 'Fey Light: Glow in darkness', color: '#ffaaff', tier: 'uncommon' },
            { name: 'Ghast', size: 'average', strMod: 2, agiMod: 1, endMod: -2, intMod: 1, passive: 'Undying: Resist first killing blow', color: '#aaaacc', tier: 'uncommon' },
            { name: 'Undine', size: 'average', strMod: 0, agiMod: 2, endMod: 0, intMod: 3, passive: 'Water Born: Breathe underwater', color: '#44aadd', tier: 'uncommon' },
            { name: 'Naiad', size: 'small', strMod: -2, agiMod: 3, endMod: -1, intMod: 3, passive: 'River Spirit: Heal near water', color: '#66ccee', tier: 'uncommon' },
            { name: 'Kindir', size: 'average', strMod: 1, agiMod: 1, endMod: 1, intMod: 1, passive: 'Balanced: Minor bonus to all stats', color: '#ddddaa', tier: 'uncommon' }
        ];

        var rareRaces = [
            { name: 'Fey', size: 'tiny', strMod: -6, agiMod: 8, endMod: -5, intMod: 7, passive: 'Fey Step: Short range teleport', color: '#88ffcc', tier: 'rare' },
            { name: 'Builder Gnome', size: 'small', strMod: -1, agiMod: 1, endMod: 2, intMod: 6, passive: 'Master Builder: 2x crafting speed', color: '#ffaa44', tier: 'rare' },
            { name: 'Pixie', size: 'tiny', strMod: -6, agiMod: 7, endMod: -4, intMod: 6, passive: 'Flutter: Slow fall and hover', color: '#ff88dd', tier: 'rare' }
        ];

        var legendaryRaces = [
            { name: 'Psi Dragonling', size: 'small', strMod: 4, agiMod: 8, endMod: 6, intMod: 15, passive: 'Mind Fire: Psychic attacks deal bonus', color: '#00ffff', tier: 'legendary' },
            { name: 'Tefonim', size: 'massive', strMod: 18, agiMod: -4, endMod: 16, intMod: 3, passive: 'Ancient Blood: Immune to fear', color: '#ffdd00', tier: 'legendary' },
            { name: 'Messeji Dragon', size: 'massive', strMod: 14, agiMod: 5, endMod: 12, intMod: 12, passive: 'Dragon Soul: Fire breath attack', color: '#ff8800', tier: 'legendary' },
            { name: 'Cherubiae', size: 'tiny', strMod: -2, agiMod: 12, endMod: 4, intMod: 18, passive: 'Divine Light: Heal allies nearby', color: '#ffffaa', tier: 'legendary' }
        ];

        var mythicRaces = [
            { name: 'Chaos Seed', size: 'average', strMod: 10, agiMod: 10, endMod: 10, intMod: 10, passive: 'Chaos Powers: All stats enhanced, unique quest', color: '#ff00ff', tier: 'mythic' }
        ];

        this.shuffleArray(commonRaces);
        this.availableRaces = commonRaces.slice();

        for (var s = 0; s < savedUnlockedRaces.length; s++) {
            this.availableRaces.push(savedUnlockedRaces[s]);
        }

        this.newUnlocks = [];
        var beatRecord = lastRunLevel > bestLevel;
        var levelsOver = beatRecord ? lastRunLevel - bestLevel : 0;
        var luckMultiplier = 1 + (levelsOver * 0.3);
        var isFirstRun = (bestLevel === 0 && lastRunLevel === 0);

        if (beatRecord) {
            bestLevel = lastRunLevel;
        }

        if (isFirstRun) {
            this.shuffleArray(uncommonRaces);
            for (var fi = 0; fi < uncommonRaces.length; fi++) {
                if (unlockedRaceNames.indexOf(uncommonRaces[fi].name) === -1) {
                    if (Math.floor(Math.random() * 3) === 0) {
                        this.availableRaces.push(uncommonRaces[fi]);
                        unlockedRaceNames.push(uncommonRaces[fi].name);
                        savedUnlockedRaces.push(uncommonRaces[fi]);
                        this.newUnlocks.push(uncommonRaces[fi]);
                    }
                }
            }
            this.shuffleArray(rareRaces);
            for (var fj = 0; fj < rareRaces.length; fj++) {
                if (unlockedRaceNames.indexOf(rareRaces[fj].name) === -1) {
                    if (Math.floor(Math.random() * 100) === 0) {
                        this.availableRaces.push(rareRaces[fj]);
                        unlockedRaceNames.push(rareRaces[fj].name);
                        savedUnlockedRaces.push(rareRaces[fj]);
                        this.newUnlocks.push(rareRaces[fj]);
                    }
                }
            }
            this.shuffleArray(legendaryRaces);
            for (var fk = 0; fk < legendaryRaces.length; fk++) {
                if (unlockedRaceNames.indexOf(legendaryRaces[fk].name) === -1) {
                    if (Math.floor(Math.random() * 10000) === 0) {
                        this.availableRaces.push(legendaryRaces[fk]);
                        unlockedRaceNames.push(legendaryRaces[fk].name);
                        savedUnlockedRaces.push(legendaryRaces[fk]);
                        this.newUnlocks.push(legendaryRaces[fk]);
                    }
                }
            }
            for (var fm = 0; fm < mythicRaces.length; fm++) {
                if (unlockedRaceNames.indexOf(mythicRaces[fm].name) === -1) {
                    if (Math.floor(Math.random() * 1000000) === 0) {
                        this.availableRaces.push(mythicRaces[fm]);
                        unlockedRaceNames.push(mythicRaces[fm].name);
                        savedUnlockedRaces.push(mythicRaces[fm]);
                        this.newUnlocks.push(mythicRaces[fm]);
                    }
                }
            }
        } else if (beatRecord && levelsOver > 0) {
            this.shuffleArray(uncommonRaces);
            for (var i = 0; i < uncommonRaces.length; i++) {
                if (unlockedRaceNames.indexOf(uncommonRaces[i].name) === -1) {
                    var uOdds = Math.max(1, Math.floor(3 / luckMultiplier));
                    if (Math.floor(Math.random() * uOdds) === 0) {
                        this.availableRaces.push(uncommonRaces[i]);
                        unlockedRaceNames.push(uncommonRaces[i].name);
                        savedUnlockedRaces.push(uncommonRaces[i]);
                        this.newUnlocks.push(uncommonRaces[i]);
                    }
                }
            }
            this.shuffleArray(rareRaces);
            for (var j = 0; j < rareRaces.length; j++) {
                if (unlockedRaceNames.indexOf(rareRaces[j].name) === -1) {
                    var rOdds = Math.max(1, Math.floor(100 / luckMultiplier));
                    if (Math.floor(Math.random() * rOdds) === 0) {
                        this.availableRaces.push(rareRaces[j]);
                        unlockedRaceNames.push(rareRaces[j].name);
                        savedUnlockedRaces.push(rareRaces[j]);
                        this.newUnlocks.push(rareRaces[j]);
                    }
                }
            }
            this.shuffleArray(legendaryRaces);
            for (var k = 0; k < legendaryRaces.length; k++) {
                if (unlockedRaceNames.indexOf(legendaryRaces[k].name) === -1) {
                    var lOdds = Math.max(1, Math.floor(10000 / luckMultiplier));
                    if (Math.floor(Math.random() * lOdds) === 0) {
                        this.availableRaces.push(legendaryRaces[k]);
                        unlockedRaceNames.push(legendaryRaces[k].name);
                        savedUnlockedRaces.push(legendaryRaces[k]);
                        this.newUnlocks.push(legendaryRaces[k]);
                    }
                }
            }
            for (var m = 0; m < mythicRaces.length; m++) {
                if (unlockedRaceNames.indexOf(mythicRaces[m].name) === -1) {
                    var mOdds = Math.max(1, Math.floor(1000000 / luckMultiplier));
                    if (Math.floor(Math.random() * mOdds) === 0) {
                        this.availableRaces.push(mythicRaces[m]);
                        unlockedRaceNames.push(mythicRaces[m].name);
                        savedUnlockedRaces.push(mythicRaces[m]);
                        this.newUnlocks.push(mythicRaces[m]);
                    }
                }
            }
        }

        this.selectedIndex = 0;
        this.selectedRace = this.availableRaces[0];
        this.scrollOffset = 0;
        this.maxVisible = 12;
        this.raceTexts = [];
        this.hoverIndex = -1;
        this.hpPreviewLabel = null;
        this.mpPreviewLabel = null;

        this.drawUI();
        this.drawRaceList();
        this.updateDetails();

        for (var n = 0; n < this.newUnlocks.length; n++) {
            this.showUnlock(this.newUnlocks[n], n);
        }
    },

    shuffleArray: function(arr) {
        for (var i = arr.length - 1; i > 0; i--) {
            var j = Math.floor(Math.random() * (i + 1));
            var temp = arr[i];
            arr[i] = arr[j];
            arr[j] = temp;
        }
    },

    showUnlock: function(race, index) {
        var delay = index * 2500;
        var self = this;
        var tierColors = { uncommon: '#44ff44', rare: '#4488ff', legendary: '#ffaa00', mythic: '#ff00ff' };
        var isFirstRun = (bestLevel === 0 && lastRunLevel === 0);

        this.time.delayedCall(delay, function() {
            var flash = self.add.graphics().setDepth(20);
            flash.fillStyle(0xffffff, 0.3);
            flash.fillRect(0, 0, 800, 600);
            self.tweens.add({ targets: flash, alpha: 0, duration: 800, onComplete: function() { flash.destroy(); } });

            var tierColor = tierColors[race.tier] || '#ffffff';
            var tierMsg = self.add.text(400, 260, race.tier.toUpperCase() + ' RACE UNLOCKED', {
                fontSize: '14px', fontFamily: 'monospace', color: tierColor, stroke: '#000000', strokeThickness: 3
            }).setOrigin(0.5).setDepth(21);

            var msg = self.add.text(400, 290, '*** ' + race.name.toUpperCase() + ' ***', {
                fontSize: '24px', fontFamily: 'monospace', color: race.color, stroke: '#000000', strokeThickness: 4
            }).setOrigin(0.5).setDepth(21);

            var luckMsg = null;
            if (!isFirstRun) {
                var luckPct = Math.round((1 + (Math.max(0, lastRunLevel - bestLevel) * 0.3)) * 100);
                luckMsg = self.add.text(400, 325, 'Record beaten! Luck: ' + luckPct + '%', {
                    fontSize: '11px', fontFamily: 'monospace', color: '#888888', stroke: '#000000', strokeThickness: 2
                }).setOrigin(0.5).setDepth(21);
            }

            var targets = [msg, tierMsg];
            if (luckMsg) targets.push(luckMsg);

            self.tweens.add({
                targets: targets, alpha: 0, y: '-=30', duration: 2000, delay: 500,
                onComplete: function() {
                    msg.destroy();
                    tierMsg.destroy();
                    if (luckMsg) luckMsg.destroy();
                }
            });
        });
    },

    drawUI: function() {
        var self = this;

        this.add.text(400, 25, '-- CHOOSE YOUR RACE --', {
            fontSize: '24px', fontFamily: 'monospace', color: '#00ff88', stroke: '#000000', strokeThickness: 3
        }).setOrigin(0.5);

        var leftBg = this.add.graphics();
        leftBg.fillStyle(0x111122, 0.9);
        leftBg.fillRect(20, 55, 220, 460);
        leftBg.lineStyle(2, 0x00ff88, 0.5);
        leftBg.strokeRect(20, 55, 220, 460);

        var rightBg = this.add.graphics();
        rightBg.fillStyle(0x111122, 0.9);
        rightBg.fillRect(260, 55, 520, 460);
        rightBg.lineStyle(2, 0x00ff88, 0.5);
        rightBg.strokeRect(260, 55, 520, 460);

        this.add.text(130, 65, '[ UP ]', {
            fontSize: '12px', fontFamily: 'monospace', color: '#00ff88', stroke: '#000000', strokeThickness: 2
        }).setOrigin(0.5).setInteractive({ useHandCursor: true }).on('pointerdown', function() { self.scrollUp(); });

        this.add.text(130, 500, '[ DOWN ]', {
            fontSize: '12px', fontFamily: 'monospace', color: '#00ff88', stroke: '#000000', strokeThickness: 2
        }).setOrigin(0.5).setInteractive({ useHandCursor: true }).on('pointerdown', function() { self.scrollDown(); });

        this.selectBtnBg = this.add.graphics();
        this.selectBtnBg.fillStyle(0x006633, 1);
        this.selectBtnBg.fillRect(290, 530, 460, 45);
        this.selectBtnBg.lineStyle(2, 0x00ff88, 1);
        this.selectBtnBg.strokeRect(290, 530, 460, 45);

        this.add.text(520, 552, 'SELECT RACE', {
            fontSize: '18px', fontFamily: 'monospace', color: '#ffffff', stroke: '#000000', strokeThickness: 2
        }).setOrigin(0.5);

        this.add.zone(520, 552, 460, 45).setInteractive({ useHandCursor: true })
            .on('pointerdown', function() { self.selectRace(); })
            .on('pointerover', function() {
                self.selectBtnBg.clear();
                self.selectBtnBg.fillStyle(0x008844, 1);
                self.selectBtnBg.fillRect(290, 530, 460, 45);
                self.selectBtnBg.lineStyle(2, 0x44ffaa, 1);
                self.selectBtnBg.strokeRect(290, 530, 460, 45);
            })
            .on('pointerout', function() {
                self.selectBtnBg.clear();
                self.selectBtnBg.fillStyle(0x006633, 1);
                self.selectBtnBg.fillRect(290, 530, 460, 45);
                self.selectBtnBg.lineStyle(2, 0x00ff88, 1);
                self.selectBtnBg.strokeRect(290, 530, 460, 45);
            });

        this.detailTitle = this.add.text(520, 75, '', {
            fontSize: '22px', fontFamily: 'monospace', color: '#ffffff', stroke: '#000000', strokeThickness: 3
        }).setOrigin(0.5);

        this.detailText = this.add.text(280, 100, '', {
            fontSize: '13px', fontFamily: 'monospace', color: '#cccccc', stroke: '#000000', strokeThickness: 2, lineSpacing: 5
        });

        var maskShape = this.add.graphics();
        maskShape.fillStyle(0xffffff);
        maskShape.fillRect(260, 95, 520, 420);
        var mask = maskShape.createGeometryMask();
        this.detailText.setMask(mask);
        maskShape.setVisible(false);

        this.detailScrollY = 0;
        this.detailBaseY = 100;

        this.detailUpBtn = this.add.text(750, 100, '^', {
            fontSize: '18px', fontFamily: 'monospace', color: '#00ff88', stroke: '#000000', strokeThickness: 2
        }).setOrigin(0.5).setInteractive({ useHandCursor: true });
        this.detailUpBtn.on('pointerdown', function() { self.scrollDetailUp(); });

        this.detailDownBtn = this.add.text(750, 500, 'v', {
            fontSize: '18px', fontFamily: 'monospace', color: '#00ff88', stroke: '#000000', strokeThickness: 2
        }).setOrigin(0.5).setInteractive({ useHandCursor: true });
        this.detailDownBtn.on('pointerdown', function() { self.scrollDetailDown(); });

        // Scroll wheel for BOTH panels
        this.input.on('wheel', function(pointer, gameObjects, deltaX, deltaY) {
            if (pointer.x >= 20 && pointer.x <= 240 && pointer.y >= 55 && pointer.y <= 515) {
                // Left panel - race list
                if (deltaY > 0) self.scrollDown();
                else if (deltaY < 0) self.scrollUp();
            } else if (pointer.x >= 260 && pointer.x <= 780 && pointer.y >= 55 && pointer.y <= 515) {
                // Right panel - details
                if (deltaY > 0) self.scrollDetailDown();
                else if (deltaY < 0) self.scrollDetailUp();
            }
        });

        this.detailBars = this.add.graphics();
    },

    scrollDetailUp: function() {
        if (this.detailScrollY > 0) {
            this.detailScrollY -= 20;
            if (this.detailScrollY < 0) this.detailScrollY = 0;
            this.detailText.setY(this.detailBaseY - this.detailScrollY);
            this.updateScrollArrows();
        }
    },

    scrollDetailDown: function() {
        var textHeight = this.detailText.height;
        var panelHeight = 400;
        var maxScroll = Math.max(0, textHeight - panelHeight);
        if (this.detailScrollY < maxScroll) {
            this.detailScrollY += 20;
            if (this.detailScrollY > maxScroll) this.detailScrollY = maxScroll;
            this.detailText.setY(this.detailBaseY - this.detailScrollY);
            this.updateScrollArrows();
        }
    },

    updateScrollArrows: function() {
        var textHeight = this.detailText.height;
        var panelHeight = 400;
        var maxScroll = Math.max(0, textHeight - panelHeight);
        this.detailUpBtn.setAlpha(this.detailScrollY > 0 ? 1 : 0.3);
        this.detailDownBtn.setAlpha(this.detailScrollY < maxScroll ? 1 : 0.3);
    },

    drawRaceList: function() {
        var i;
        for (i = 0; i < this.raceTexts.length; i++) { this.raceTexts[i].destroy(); }
        this.raceTexts = [];
        var startY = 85;
        var visible = Math.min(this.maxVisible, this.availableRaces.length - this.scrollOffset);
        var self = this;
        this.hoverIndex = -1;
        var tierColors = { common: '#666666', uncommon: '#44ff44', rare: '#4488ff', legendary: '#ffaa00', mythic: '#ff00ff' };

        for (i = 0; i < visible; i++) {
            var raceIndex = i + this.scrollOffset;
            var race = this.availableRaces[raceIndex];
            var y = startY + i * 32;
            var isSelected = (raceIndex === this.selectedIndex);
            var prefix = isSelected ? '> ' : '  ';
            var displayName = race.name;
            if (race.tier === 'rare') displayName = '+ ' + displayName;
            else if (race.tier === 'legendary') displayName = '** ' + displayName;
            else if (race.tier === 'mythic') displayName = '*** ' + displayName;
            var color = isSelected ? race.color : (tierColors[race.tier] || '#666666');
            var size = isSelected ? '14px' : '12px';

            var text = this.add.text(30, y, prefix + displayName, {
                fontSize: size, fontFamily: 'monospace', color: color, stroke: '#000000', strokeThickness: 2
            }).setInteractive({ useHandCursor: true });

            (function(idx, textObj, defaultColor) {
                textObj.on('pointerover', function() { self.hoverIndex = idx; if (idx !== self.selectedIndex) textObj.setColor('#ffffff'); });
                textObj.on('pointerout', function() { if (self.hoverIndex === idx) self.hoverIndex = -1; if (idx !== self.selectedIndex) textObj.setColor(defaultColor); });
                textObj.on('pointerdown', function() { self.hoverIndex = -1; self.selectedIndex = idx; self.selectedRace = self.availableRaces[idx]; self.drawRaceList(); self.updateDetails(); });
            })(raceIndex, text, color);
            this.raceTexts.push(text);
        }
    },

    updateDetails: function() {
        var race = this.selectedRace;
        var baseStr = 10, baseAgi = 8, baseEnd = 12, baseInt = 7;
        var totalStr = baseStr + race.strMod, totalAgi = baseAgi + race.agiMod;
        var totalEnd = baseEnd + race.endMod, totalInt = baseInt + race.intMod;
        var maxHp = 50 + (totalEnd * 5), maxMp = 20 + (totalInt * 5);
        var atkMin = Math.max(1, 5 + Math.floor(totalStr * 0.8) - 2);
        var atkMax = 5 + Math.floor(totalStr * 0.8) + 2;
        var critPct = (totalAgi * 1.5).toFixed(1);
        var sign = function(val) { return val >= 0 ? '+' + val : '' + val; };
        var tierTag = '';
        if (race.tier === 'uncommon') tierTag = '  [ UNCOMMON ]\n';
        else if (race.tier === 'rare') tierTag = '  [ RARE ]\n';
        else if (race.tier === 'legendary') tierTag = '  *** LEGENDARY ***\n';
        else if (race.tier === 'mythic') tierTag = '  ***** MYTHIC *****\n';

        this.detailTitle.setText('-- ' + race.name.toUpperCase() + ' --');
        this.detailTitle.setColor(race.color);
        this.detailText.setText([tierTag, '  Size: ' + race.size.toUpperCase(), '', '  ATTRIBUTES', '  ─────────────────────────',
            '  STR:  ' + baseStr + '  (' + sign(race.strMod) + ')  = ' + totalStr,
            '  AGI:  ' + baseAgi + '  (' + sign(race.agiMod) + ')  = ' + totalAgi,
            '  END:  ' + baseEnd + '  (' + sign(race.endMod) + ')  = ' + totalEnd,
            '  INT:  ' + baseInt + '  (' + sign(race.intMod) + ')  = ' + totalInt,
            '', '  VITALS', '  ─────────────────────────', '  HP:  ' + maxHp, '  MP:  ' + maxMp,
            '', '  COMBAT', '  ─────────────────────────', '  Attack:  ' + atkMin + ' - ' + atkMax, '  Crit:    ' + critPct + '%',
            '', '  PASSIVE', '  ─────────────────────────', '  ' + race.passive]);
        this.detailScrollY = 0;
        this.detailText.setY(this.detailBaseY);
        this.updateScrollArrows();
        if (this.hpPreviewLabel) { this.hpPreviewLabel.destroy(); this.hpPreviewLabel = null; }
        if (this.mpPreviewLabel) { this.mpPreviewLabel.destroy(); this.mpPreviewLabel = null; }
        this.detailBars.clear();
    },

    scrollUp: function() { if (this.scrollOffset > 0) { this.scrollOffset--; this.drawRaceList(); } },
    scrollDown: function() { if (this.scrollOffset < this.availableRaces.length - this.maxVisible) { this.scrollOffset++; this.drawRaceList(); } },
    selectRace: function() { this.scene.start('mainScene', { race: this.selectedRace }); }
});


var mainScene = new Phaser.Class({
    Extends: Phaser.Scene,
    initialize: function mainScene() { Phaser.Scene.call(this, { key: 'mainScene' }); },

    init: function(data) {
        this.baseStats = { strength: 10, agility: 8, endurance: 12, intelligence: 7 };
        if (data && data.race) { this.race = data.race; }
        else { this.race = { name: 'Human', size: 'average', strMod: 0, agiMod: 0, endMod: 0, intMod: 0, passive: 'Adaptable', color: '#cccccc', tier: 'common' }; }
        this.stats = { level: 1, xp: 0, xpToNext: 100, skillPoints: 0,
            strength: this.baseStats.strength + this.race.strMod, agility: this.baseStats.agility + this.race.agiMod,
            endurance: this.baseStats.endurance + this.race.endMod, intelligence: this.baseStats.intelligence + this.race.intMod };
        this.stats.maxHealth = 50 + (this.stats.endurance * 5); this.stats.health = this.stats.maxHealth;
        this.stats.maxMana = 20 + (this.stats.intelligence * 5); this.stats.mana = this.stats.maxMana;
        this.attackCooldown = false; this.attackRange = 100; this.attackDuration = 200; this.cooldownTime = 400;
        this.enemies = []; this.isAttacking = false; this.facingDirection = 'right';
        this.quickHudVisible = false; this.fullHudVisible = false; this.regenTimer = 0;
        this.playerInvuln = false; this.totalKills = 0;
    },

    create: function() {
