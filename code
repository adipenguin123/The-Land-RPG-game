            e.setData('projectileTexture',t.projectileTexture||'projectile_red');e.setData('aggroRange',t.aggroRange||150);
            var tc=Phaser.Display.Color.HexStringToColor(t.color);e.setTint(tc.color);e.setScale(t.scale||1);
            e.setVelocity(Phaser.Math.Between(-t.speed,t.speed),Phaser.Math.Between(-t.speed,t.speed));this.enemies.push(e);
        }
    },

    getEnemyTypesForLevel: function(l) {
        var t=[];
        t.push({name:'Goblin',health:25+l*3,damage:4+Math.floor(l*0.5),xp:12+l*2,speed:40,color:'#ff3333',scale:1});
        if(l>=2)t.push({name:'Wolf',health:20+l*2,damage:6+Math.floor(l*0.7),xp:18+l*3,speed:110,color:'#888888',scale:0.9,aggroRange:200});
        if(l>=3)t.push({name:'Orc',health:45+l*5,damage:8+l,xp:25+l*4,speed:35,color:'#44aa44',scale:1.2,shoots:true,projectileSpeed:100,projectileDamage:6+Math.floor(l*0.8),shootCooldown:3000,projectileTexture:'projectile_red',aggroRange:200});
        if(l>=5)t.push({name:'Dark Knight',health:60+l*6,damage:10+l,xp:40+l*5,speed:60,color:'#6633aa',scale:1.1,shoots:true,projectileSpeed:130,projectileDamage:9+l,shootCooldown:2500,projectileTexture:'projectile_purple',aggroRange:250});
        if(l>=7)t.push({name:'Demon',health:80+l*8,damage:14+l*2,xp:60+l*6,speed:75,color:'#ff4400',scale:1.3,shoots:true,projectileSpeed:150,projectileDamage:12+l,shootCooldown:2000,projectileTexture:'projectile_fire',aggroRange:280});
        if(l>=10)t.push({name:'Dragon Whelp',health:120+l*10,damage:18+l*2,xp:100+l*8,speed:65,color:'#ff8800',scale:1.5,shoots:true,projectileSpeed:120,projectileDamage:16+l*2,shootCooldown:1800,projectileTexture:'projectile_fire',aggroRange:300});
        return t;
    },

    handleEnemyContact: function(p,e) { if(!e.active)return;this.damagePlayer(e.getData('damage'));var a=Phaser.Math.Angle.Between(e.x,e.y,p.x,p.y);p.setVelocity(Math.cos(a)*150,Math.sin(a)*150); },
    handleProjectileHit: function(p,pr) { if(!pr.active)return;this.damagePlayer(pr.getData('damage')||5);var a=Phaser.Math.Angle.Between(pr.x,pr.y,p.x,p.y);p.setVelocity(Math.cos(a)*100,Math.sin(a)*100);pr.destroy(); },

    damagePlayer: function(amount) {
        if(this.playerInvuln)return;
        this.stats.health=Math.max(0,this.stats.health-amount);this.playerInvuln=true;
        this.showDamageNumber(this.player.x,this.player.y-20,amount,false,true);
        this.player.setTint(0xff0000);var self=this;
        this.time.delayedCall(500,function(){var rc=Phaser.Display.Color.HexStringToColor(self.race.color);self.player.setTint(rc.color);self.playerInvuln=false;});
        if(this.stats.health<=0){
            lastRunLevel=this.stats.level;lastRunKills=this.totalKills;
            var beat=lastRunLevel>bestLevel;var over=beat?lastRunLevel-bestLevel:0;
            this.add.text(400,230,'YOU HAVE DIED',{fontSize:'32px',fontFamily:'monospace',color:'#ff0000',stroke:'#000000',strokeThickness:4}).setOrigin(0.5).setDepth(50);
            this.add.text(400,280,'Level: '+lastRunLevel+'  Kills: '+lastRunKills,{fontSize:'14px',fontFamily:'monospace',color:'#aaaaaa',stroke:'#000000',strokeThickness:3}).setOrigin(0.5).setDepth(50);
            if(beat){
                this.add.text(400,310,'NEW RECORD! +'+over+' past previous best!',{fontSize:'14px',fontFamily:'monospace',color:'#ffaa00',stroke:'#000000',strokeThickness:3}).setOrigin(0.5).setDepth(50);
                this.add.text(400,340,'New races may appear! (Luck boosted!)',{fontSize:'14px',fontFamily:'monospace',color:'#44ff44',stroke:'#000000',strokeThickness:3}).setOrigin(0.5).setDepth(50);
            } else {
                this.add.text(400,310,'Best: Lv.'+bestLevel+'  (No new race rolls)',{fontSize:'14px',fontFamily:'monospace',color:'#666666',stroke:'#000000',strokeThickness:3}).setOrigin(0.5).setDepth(50);
            }
            this.player.setVelocity(0);this.physics.pause();
            this.time.delayedCall(3000,function(){self.physics.resume();self.scene.start('SelectScene');});
        }
    },

    meleeAttack: function() {
        if(this.attackCooldown||this.isAttacking)return;this.isAttacking=true;this.attackCooldown=true;
        var o=this.attackRange/2+16,sx=this.player.x,sy=this.player.y,a=0;
        switch(this.facingDirection){case'right':sx+=o;a=0;break;case'left':sx-=o;a=180;break;case'up':sy-=o;a=-90;break;case'down':sy+=o;a=90;break;}
        var sw=this.add.sprite(sx,sy,'swing');sw.setAlpha(0.6);sw.setAngle(a);sw.setDepth(2);this.player.setTint(0xffffff);
        var self=this;
        this.enemyGroup.getChildren().forEach(function(e){if(!e.active)return;var d=Phaser.Math.Distance.Between(self.player.x,self.player.y,e.x,e.y);if(d<=self.attackRange&&self.isInAttackArc(e))self.damageEnemy(e);});
        this.time.delayedCall(this.attackDuration,function(){sw.destroy();self.player.clearTint();self.isAttacking=false;});
        this.time.delayedCall(this.cooldownTime,function(){self.attackCooldown=false;});
    },

    isInAttackArc: function(e) { var dx=e.x-this.player.x,dy=e.y-this.player.y;switch(this.facingDirection){case'right':return dx>0;case'left':return dx<0;case'up':return dy<0;case'down':return dy>0;}return false; },

    damageEnemy: function(e) {
        var bd=5,sb=Math.floor(this.stats.strength*0.8),v=Phaser.Math.Between(-2,2),td=Math.max(1,bd+sb+v);
        var cc=this.stats.agility*1.5,ic=Phaser.Math.Between(1,100)<=cc,fd=ic?td*2:td;
        var ch=e.getData('health')-fd;e.setData('health',ch);
        this.showDamageNumber(e.x,e.y-20,fd,ic,false);
        var a=Phaser.Math.Angle.Between(this.player.x,this.player.y,e.x,e.y);e.setVelocity(Math.cos(a)*200,Math.sin(a)*200);
        e.setTint(0xff0000);this.time.delayedCall(150,function(){if(e.active)e.clearTint();});
        if(ch<=0)this.killEnemy(e);
    },

    killEnemy: function(e) {
        var xp=e.getData('xpReward'),nm=e.getData('name'),self=this;this.totalKills++;
        this.tweens.add({targets:e,alpha:0,scaleX:1.5,scaleY:1.5,duration:300,onComplete:function(){e.destroy();self.enemies=self.enemies.filter(function(x){return x!==e;});}});
        this.gainXP(xp);this.showNotification(nm+' slain! +'+xp+' XP');
        this.time.delayedCall(3000,function(){self.spawnEnemies(1);});
    },

    updateEnemyAI: function() {
        var self=this,now=this.time.now;
        this.enemyGroup.getChildren().forEach(function(e){
            if(!e.active)return;var d=Phaser.Math.Distance.Between(self.player.x,self.player.y,e.x,e.y);
            var ar=e.getData('aggroRange')||150,cs=e.getData('speed')||80;
            if(d<ar){var a=Phaser.Math.Angle.Between(e.x,e.y,self.player.x,self.player.y);
                if(e.getData('shoots')){var pd=120;
                    if(d<pd)e.setVelocity(Math.cos(a)*-cs*0.5,Math.sin(a)*-cs*0.5);
                    else if(d>pd+60)e.setVelocity(Math.cos(a)*cs,Math.sin(a)*cs);
                    else{var sa=a+(Math.random()>0.5?Math.PI/2:-Math.PI/2);e.setVelocity(Math.cos(sa)*cs*0.6,Math.sin(sa)*cs*0.6);}
                    var ls=e.getData('lastShot')||0,cd=e.getData('shootCooldown')||3000;
                    if(now-ls>=cd){self.enemyShoot(e);e.setData('lastShot',now);}
                }else{e.setVelocity(Math.cos(a)*cs,Math.sin(a)*cs);}}
        });
        this.projectileGroup.getChildren().forEach(function(p){if(!p.active)return;if(p.x<-20||p.x>820||p.y<-20||p.y>620)p.destroy();var b=p.getData('born')||0;if(now-b>4000)p.destroy();});
    },

    enemyShoot: function(e) {
        var a=Phaser.Math.Angle.Between(e.x,e.y,this.player.x,this.player.y);
        var tn=e.getData('projectileTexture')||'projectile_red',ps=e.getData('projectileSpeed')||100,pd=e.getData('projectileDamage')||5;
        var p=this.projectileGroup.create(e.x,e.y,tn);p.setDepth(3);p.setData('damage',pd);p.setData('born',this.time.now);p.body.setAllowGravity(false);
        p.setVelocity(Math.cos(a)*ps,Math.sin(a)*ps);p.setRotation(a);
    },

    spawnMedBox: function() {
        var x=Phaser.Math.Between(100,700),y=Phaser.Math.Between(80,520);
        var mb=this.medBoxGroup.create(x,y,'medbox');mb.setDepth(1);mb.body.setAllowGravity(false);mb.body.setImmovable(true);
        mb.setData('healAmount',Math.floor(20+this.stats.maxHealth*0.3));
        this.tweens.add({targets:mb,scaleX:1.2,scaleY:1.2,alpha:0.7,duration:800,yoyo:true,repeat:-1,ease:'Sine.easeInOut'});
        var self=this;this.time.delayedCall(30000,function(){if(mb.active)self.tweens.add({targets:mb,alpha:0,duration:500,onComplete:function(){mb.destroy();}});});
    },

    handleMedBoxPickup: function(p,mb) {
        if(!mb.active)return;var ha=mb.getData('healAmount')||25,ah=Math.min(ha,this.stats.maxHealth-this.stats.health);
        if(ah<=0)return;this.stats.health=Math.min(this.stats.health+ha,this.stats.maxHealth);
        var mr=Math.floor(ha*0.5);this.stats.mana=Math.min(this.stats.mana+mr,this.stats.maxMana);
        this.showNotification('+'+ah+' HP healed!');this.player.setTint(0x00ff44);
        var self=this;this.time.delayedCall(300,function(){var rc=Phaser.Display.Color.HexStringToColor(self.race.color);self.player.setTint(rc.color);});
        var ht=this.add.text(p.x,p.y-30,'+'+ah,{fontSize:'16px',fontFamily:'monospace',color:'#00ff44',fontStyle:'bold',stroke:'#000000',strokeThickness:3}).setOrigin(0.5).setDepth(10);
        this.tweens.add({targets:ht,y:ht.y-40,alpha:0,duration:1000,ease:'Power2',onComplete:function(){ht.destroy();}});mb.destroy();
    },

    showDamageNumber: function(x,y,a,ic,ip) {
        var c=ip?'#ff4444':(ic?'#ffaa00':'#ffffff'),s=ic?'20px':'14px',p=ic?'CRIT! ':'';
        var t=this.add.text(x,y,p+'-'+a,{fontSize:s,fontFamily:'monospace',color:c,fontStyle:'bold',stroke:'#000000',strokeThickness:3}).setOrigin(0.5).setDepth(10);
        this.tweens.add({targets:t,y:y-40,alpha:0,duration:800,ease:'Power2',onComplete:function(){t.destroy();}});
    },

    showNotification: function(m) {
        var t=this.add.text(400,50,m,{fontSize:'16px',fontFamily:'monospace',color:'#44ff44',stroke:'#000000',strokeThickness:4}).setOrigin(0.5).setDepth(10);
        this.tweens.add({targets:t,y:30,alpha:0,duration:2000,onComplete:function(){t.destroy();}});
    },

    drawEnemyHealthBars: function() {
        if(this.enemyBars)this.enemyBars.clear();else this.enemyBars=this.add.graphics().setDepth(5);
        var self=this;this.enemyGroup.getChildren().forEach(function(e){if(!e.active)return;
            var h=e.getData('health'),mh=e.getData('maxHealth'),r=Math.max(0,h/mh),bw=30,x=e.x-bw/2,y=e.y-22;
            self.enemyBars.fillStyle(0x333333,0.8);self.enemyBars.fillRect(x,y,bw,4);
            self.enemyBars.fillStyle(r>0.5?0x00ff00:0xff0000,1);self.enemyBars.fillRect(x,y,bw*r,4);});
    },

    update: function() {
        var sp=200;this.player.setVelocity(0);
        if(this.cursors.left.isDown||this.wasd.left.isDown){this.player.setVelocityX(-sp);this.facingDirection='left';}
        else if(this.cursors.right.isDown||this.wasd.right.isDown){this.player.setVelocityX(sp);this.facingDirection='right';}
        if(this.cursors.up.isDown||this.wasd.up.isDown){this.player.setVelocityY(-sp);this.facingDirection='up';}
        else if(this.cursors.down.isDown||this.wasd.down.isDown){this.player.setVelocityY(sp);this.facingDirection='down';}
        var vx=this.player.body.velocity.x,vy=this.player.body.velocity.y;
        if(vx!==0&&vy!==0)this.player.setVelocity(vx*0.707,vy*0.707);
        if(this.race.name==='Troll'){this.regenTimer+=this.game.loop.delta;if(this.regenTimer>=2000){this.regenTimer=0;if(this.stats.health<this.stats.maxHealth)this.stats.health=Math.min(this.stats.health+1,this.stats.maxHealth);}}
        this.updateEnemyAI();this.updateHUD();this.drawEnemyHealthBars();
    }
});

